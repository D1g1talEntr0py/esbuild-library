{
	"compilerOptions": {
		"strict": true,
		"allowJs": false,
		"checkJs": false,
		"declaration": true,
		"useDefineForClassFields": true,
		"resolveJsonModule": true,
		"module": "ESNext",
		"target": "ESNext",
		"lib": [ "ESNext" ],
		"outDir": "./dist",
		"moduleResolution": "Bundler"
	},
	"include": [ "src/" ],
	"exclude": [ "node_modules", "dist"	]
}